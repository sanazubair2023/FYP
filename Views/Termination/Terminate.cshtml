@model MaidAndServantt.Models.TerminationViewModel
@{
    ViewData["Title"] = "Terminate Contract";
}

<!-- Bootstrap Icons Setup CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #FFF;
        font-family: 'Segoe UI', sans-serif;
        position: relative;
    }

    .blue-circle {
        position: absolute;
        top: -40px;
        left: -40px;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background-color: #E3F2FD;
        z-index: -1;
    }

    .header-area {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 15px;
        margin-bottom: 25px;
    }

    .back-btn {
        background-color: #E3F2FD;
        border: none;
        border-radius: 50%;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1E64D3;
    }

    .header-title {
        font-size: 22px;
        font-weight: bold;
        color: #000;
        margin-left: 10px;
    }

    .worker-card {
        background-color: #FFF;
        border-radius: 16px;
        padding: 12px 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        border: 1px solid #EAEAEA;
        display: flex;
        align-items: center;
        margin-bottom: 30px;
    }

    .avatar-img {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 15px;
    }

    .w-name {
        font-size: 19px;
        font-weight: bold;
        color: #000;
        margin-bottom: 0px;
    }

    .w-role {
        font-size: 14px;
        color: #888;
    }

    .form-group-custom {
        margin-bottom: 22px;
    }

    .label-custom {
        font-size: 13.5px;
        font-weight: 700;
        color: #000;
        margin-bottom: 6px;
        display: block;
    }

    .input-custom {
        border-radius: 12px;
        border: 1.5px solid #CCC;
        padding: 10px 15px;
        font-size: 14px;
        outline: none;
        width: 100%;
    }

    .remarks-box {
        background: #FFF;
        border-radius: 16px;
        border: 1.5px solid #CCC;
        padding: 15px;
        margin-bottom: 25px;
    }

    .stars-row {
        display: flex;
        justify-content: flex-end;
        gap: 4px;
        margin-bottom: 8px;
    }

        .stars-row i {
            font-size: 20px;
            color: #CCC;
            cursor: pointer;
            transition: color 0.15s ease-in-out;
        }

            .stars-row i.active {
                color: #FFB300;
            }

    .textarea-custom {
        border: none;
        outline: none;
        width: 100%;
        resize: none;
        font-size: 13.5px;
        color: #333;
    }

    .confirm-checkbox {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        font-size: 12px;
        color: #111;
        font-weight: 500;
        margin-bottom: 30px;
    }

        .confirm-checkbox input {
            margin-top: 3px;
            transform: scale(1.1);
        }

    .btn-submit-red {
        background-color: #E53935;
        color: #FFF;
        font-weight: 700;
        font-size: 16px;
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 8px rgba(229, 57, 53, 0.3);
        margin-bottom: 15px;
    }

    .btn-cancel-flat {
        background: none;
        border: none;
        color: #000;
        font-weight: 700;
        font-size: 15px;
        width: 100%;
        text-align: center;
        display: block;
        text-decoration: none;
    }
</style>

<div class="blue-circle"></div>

<div class="container py-2" style="max-width: 410px;">

    <div class="header-area">
        <div class="d-flex align-items-center">
            <button class="back-btn" onclick="window.history.back()"><i class="bi bi-arrow-left fs-5"></i></button>
            <span class="header-title">Terminate Contract</span>
        </div>
        <img src="/Images/logo.png" alt="Logo" style="height: 38px; object-fit: contain;" onerror="this.style.display='none'">
    </div>

    <div class="worker-card">
        <img src="@Model.WorkerImage" class="avatar-img" alt="Worker Avatar" onerror="this.src='https://cdn-icons-png.flaticon.com/512/3135/3135715.png'">
        <div>
            <div class="w-name">@Model.WorkerName</div>
            <div class="w-role">@Model.WorkerSkill</div>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger py-2" style="font-size: 13px;">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-controller="Termination" asp-action="Terminate" method="post" id="terminationForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="InterviewId" />

        <!-- HIDDEN TARGET FOR STAR RATING VALUES -->
        <input type="hidden" asp-for="Rating" id="ratingInput" value="5" />

        <div class="form-group-custom">
            <label class="label-custom">Termination Reason</label>
            <input type="text" asp-for="TerminatedReason" class="input-custom" placeholder="Enter a Reason" required />
        </div>

        <div class="form-group-custom">
            <label class="label-custom">Last Working Day</label>
            <input type="date" asp-for="LastWorkingDay" class="input-custom" id="datePicker" required />
        </div>

        <!-- STARRING SYSTEM CONTROLS -->
        <div class="remarks-box">
            <div class="stars-row" id="starsContainer">
                <i class="bi bi-star-fill active" data-value="1"></i>
                <i class="bi bi-star-fill active" data-value="2"></i>
                <i class="bi bi-star-fill active" data-value="3"></i>
                <i class="bi bi-star-fill active" data-value="4"></i>
                <i class="bi bi-star-fill active" data-value="5"></i>
            </div>
            <textarea asp-for="Comment" class="textarea-custom" rows="2" placeholder="Enter your remarks here"></textarea>
        </div>

        <div class="confirm-checkbox">
            <input type="checkbox" id="agreeCheck" required />
            <label for="agreeCheck">
                I confirm that i want to terminate this contract and have cleared all dues as per the settlement summary above.
            </label>
        </div>

        <button type="submit" class="btn-submit-red">Confirm Termination</button>
        <a asp-controller="WorkerDecision" asp-action="JobRequests" class="btn-cancel-flat">Cancel</a>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 1. Autofill today's date safely
        const today = new Date().toISOString().split('T')[0];
        document.getElementById("datePicker").value = today;

        // 2. Interactive Clickable Stars Rating Logic
        const stars = document.querySelectorAll("#starsContainer i");
        const ratingInput = document.getElementById("ratingInput");

        stars.forEach(star => {
            star.addEventListener("click", function() {
                const selectedVal = parseInt(this.getAttribute("data-value"));
                ratingInput.value = selectedVal; // Update hidden input

                // Update UI active state colors
                stars.forEach((s, idx) => {
                    if (idx < selectedVal) {
                        s.classList.add("active");
                    } else {
                        s.classList.remove("active");
                    }
                });
            });
        });
    });

    document.getElementById("terminationForm").addEventListener("submit", function(e) {
        const checkbox = document.getElementById("agreeCheck");
        if (!checkbox.checked) {
            e.preventDefault();
            alert("Please acknowledge the termination declaration to proceed.");
        }
    });
</script>