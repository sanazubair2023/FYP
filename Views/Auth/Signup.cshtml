                <div class="custom-input-group justify-content-between pe-1" id="lnkAddSkills" style="cursor: pointer;">
                    <div class="d-flex align-items-center flex-grow-1" style="gap: 8px;">
                        <div class="icon-circle" id="skillsCheckIcon" style="background: #fee2e2; color: #dc2626; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.95rem;">
                            <i class="fa-solid fa-xmark"></i>
                        </div>
                        <span class="text-secondary fs-6" id="skillsStatusText" style="font-weight: 500; margin: 0;">Add Skills and Experience</span>
                    </div>
                    <button class="icon-circle border-0 text-primary" style="background: #dbeafe; color: #1e74ed; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; cursor: pointer;" type="button" onclick="event.stopPropagation();">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </div>

                <div class="custom-input-group">
                    <div class="icon-circle"><i class="fa-solid fa-lock"></i></div>
                    <input id="workerPass" name="WorkerPassword" placeholder="Password" type="password" />
                    <div class="icon-circle" onclick="togglePass('workerPass', 'workerPassIcon')" style="cursor: pointer;">
                        <i class="fa-regular fa-eye-slash" id="workerPassIcon"></i>
                    </div>
                </div>
                <div class="custom-input-group">
                    <div class="icon-circle"><i class="fa-solid fa-lock"></i></div>
                    <input id="workerConfirmPass" name="WorkerConfirmPassword" placeholder="Confirm Password" type="password" />
                    <div class="icon-circle" onclick="togglePass('workerConfirmPass', 'workerConfirmPassIcon')" style="cursor: pointer;">
                        <i class="fa-regular fa-eye-slash" id="workerConfirmPassIcon"></i>
                    </div>
                </div>

                <div class="action-row">
                    <button class="btn-action-blue" onclick="backToWorkerStep1()" type="button">Back</button>
                    <button class="btn-action-blue" id="btnFinalSubmit" type="submit">Submit</button>
                </div>
            </div>
        </form>
    </div>

    <script>
            document.addEventListener("DOMContentLoaded", function () {
                // Initial control sync based on default page landing state (Client)
                manageRequiredAttributes('Client');

                // Check if user is returning back into this context layout from AddSkills view state
                if (localStorage.getItem("worker_form_backstate") === "true") {

                    // Switch Context Panels to Worker view sequence
                    switchRole('Worker');

                    // Skip directly to Step 2 Panel
                    document.getElementById('roleSelectionWrapper').style.display = 'none';
                    document.getElementById('panelWorkerStep1').classList.remove('active');
                    document.getElementById('panelWorkerStep2').classList.add('active');

                    // Populating text fields values back out of tracking store
                    document.getElementsByName("WorkerName")[0].value = localStorage.getItem("w_name") || "";
                    document.getElementsByName("WorkerAge")[0].value = localStorage.getItem("w_age") || "";
                    document.getElementsByName("WorkerPhone")[0].value = localStorage.getItem("w_phone") || "";
                    document.getElementsByName("WorkerCNIC")[0].value = localStorage.getItem("w_cnic") || "";
                    document.getElementsByName("WorkerSalary")[0].value = localStorage.getItem("w_salary") || "";
                    document.getElementsByName("WorkerGender")[0].value = localStorage.getItem("w_gender") || "";
                    document.getElementsByName("WorkerEmail")[0].value = localStorage.getItem("w_email") || "";
                    document.getElementsByName("WorkerAddress")[0].value = localStorage.getItem("w_address") || "";
                    document.getElementById("workerPass").value = localStorage.getItem("w_pass") || "";
                    document.getElementById("workerConfirmPass").value = localStorage.getItem("w_cpass") || "";

                    // Restoring dynamic skills submission block references
                    var savedSkills = localStorage.getItem("worker_skills_json");

                    // If no localStorage data, check sessionStorage (from AddSkills return)
                    if (!savedSkills && sessionStorage.getItem("WorkerSignupData")) {
                        var signupData = JSON.parse(sessionStorage.getItem("WorkerSignupData"));
                        if (signupData && signupData.skillsData) {
                            savedSkills = JSON.stringify(signupData.skillsData);
                            localStorage.setItem("worker_skills_json", savedSkills);
                        }
                    }

                    if (savedSkills) {
                        document.getElementById("SessionSkillsData").value = savedSkills;
                        document.getElementById("skillsStatusText").innerText = "Skills Added Successfully!";
                        document.getElementById("skillsStatusText").classList.remove("text-secondary");
                        document.getElementById("skillsStatusText").classList.add("text-success", "fw-bold");
                        // Update icon from X to checkmark when skills are filled
                        const skillsCheckIcon = document.getElementById("skillsCheckIcon");
                        skillsCheckIcon.style.background = "#d1fae5";
                        skillsCheckIcon.style.color = "#059669";
                        skillsCheckIcon.innerHTML = '<i class="fa-solid fa-check" style="font-size: 1.1rem;"></i>';
                    }

                    // Restore image reference state safely if present
                    var savedPicPath = localStorage.getItem("w_pic_temp");
                    if (savedPicPath) {
                        document.getElementById("TempPicturePath").value = savedPicPath;
                        document.getElementById("tempImagePreview").src = savedPicPath;
                        document.getElementById("tempImagePreviewContainer").style.display = "block";
                    }

                    // Remove tracking variables to clean context state loops
                    localStorage.removeItem("worker_form_backstate");
                }

                // Intercepting navigation triggers to cache inputs locally before leaving view context bounds
                document.getElementById("lnkAddSkills").addEventListener("click", async function(e) {
                    e.preventDefault();

                    // Save textual entries to storage block
                    localStorage.setItem("w_name", document.getElementsByName("WorkerName")[0].value);
                    localStorage.setItem("w_age", document.getElementsByName("WorkerAge")[0].value);
                    localStorage.setItem("w_phone", document.getElementsByName("WorkerPhone")[0].value);
                    localStorage.setItem("w_cnic", document.getElementsByName("WorkerCNIC")[0].value);
                    localStorage.setItem("w_salary", document.getElementsByName("WorkerSalary")[0].value);
                    localStorage.setItem("w_gender", document.getElementsByName("WorkerGender")[0].value);
                    localStorage.setItem("w_email", document.getElementsByName("WorkerEmail")[0].value);
                    localStorage.setItem("w_address", document.getElementsByName("WorkerAddress")[0].value);
                    localStorage.setItem("w_pass", document.getElementById("workerPass").value);
                    localStorage.setItem("w_cpass", document.getElementById("workerConfirmPass").value);
                    localStorage.setItem("worker_form_backstate", "true");

                    // Check and pass file targets across background pipelines asynchronously
                    var fileInput = document.getElementById("workerPicInput");
                    if (fileInput && fileInput.files.length > 0) {
                        var formData = new FormData();
                        formData.append("file", fileInput.files[0]);

                        try {
                            let response = await fetch('/Auth/UploadTemporaryPicture', {
                                method: 'POST',
                                body: formData
                            });
                            let result = await response.json();
                            if (result.success) {
                                localStorage.setItem("w_pic_temp", result.filePath);
                            }
                        } catch (err) {
                            console.error("Error standardizing temporary upload file streams:", err);
                        }
                    }

                    window.location.href = '@Url.Action("AddSkills", "Auth")';
                });

                // Clean data persistence objects upon definitive submission runs
                document.getElementById("signupForm").addEventListener("submit", function() {
                    localStorage.clear();
                });
            });

            // Dynamically add/remove standard validation markers depending on what role is active
            function manageRequiredAttributes(role) {
                const clientFields = ['ClientName', 'ClientEmail', 'ClientPhone', 'ClientPassword', 'ClientConfirmPassword'];
                const workerFields = ['WorkerName', 'WorkerAge', 'WorkerPhone', 'WorkerCNIC', 'WorkerSalary', 'WorkerGender', 'WorkerEmail', 'WorkerPassword', 'WorkerConfirmPassword'];

                if (role === 'Client') {
                    // Turn client fields on
                    clientFields.forEach(name => {
                        let el = document.getElementsByName(name)[0];
                        if(el) el.setAttribute('required', 'required');
                    });
                    // Remove worker constraints
                    workerFields.forEach(name => {
                        let el = document.getElementsByName(name)[0];
                        if(el) el.removeAttribute('required');
                    });
                } else {
                    // Remove client constraints
                    clientFields.forEach(name => {
                        let el = document.getElementsByName(name)[0];
                        if(el) el.removeAttribute('required');
                    });
                    // Turn specific vital worker fields on
                    const mandatoryWorker = ['WorkerName', 'WorkerPhone', 'WorkerCNIC', 'WorkerEmail', 'WorkerPassword', 'WorkerConfirmPassword'];
                    mandatoryWorker.forEach(name => {
                        let el = document.getElementsByName(name)[0];
                        if(el) el.setAttribute('required', 'required');
                    });
                }
            }

            function switchRole(role) {
                document.getElementById('selectedRole').value = role;
                manageRequiredAttributes(role);

                if(role === 'Client') {
                    document.getElementById('roleClient').classList.add('active');
                    document.getElementById('roleWorker').classList.remove('active');

                    document.getElementById('panelClient').classList.add('active');
                    document.getElementById('panelWorkerStep1').classList.remove('active');
                    document.getElementById('panelWorkerStep2').classList.remove('active');
                } else {
                    document.getElementById('roleWorker').classList.add('active');
                    document.getElementById('roleClient').classList.remove('active');

                    document.getElementById('panelWorkerStep1').classList.add('active');
                    document.getElementById('panelClient').classList.remove('active');
                    document.getElementById('panelWorkerStep2').classList.remove('active');
                }
            }

            function nextWorkerStep() {
                document.getElementById('roleSelectionWrapper').style.display = 'none';
                document.getElementById('panelWorkerStep1').classList.remove('active');
                document.getElementById('panelWorkerStep2').classList.add('active');
            }

            function backToWorkerStep1() {
                document.getElementById('roleSelectionWrapper').style.display = 'block';
                document.getElementById('panelWorkerStep2').classList.remove('active');
                document.getElementById('panelWorkerStep1').classList.add('active');
            }

            function goToLogin() {
                window.location.href = '@Url.Action("Login", "Auth")';
            }

            function togglePass(fieldId, iconId) {
                var field = document.getElementById(fieldId);
                var icon = document.getElementById(iconId);
                if (field.type === "password") {
                    field.type = "text";
                    icon.className = "fa-regular fa-eye";
                } else {
                    field.type = "password";
                    icon.className = "fa-regular fa-eye-slash";
                }
            }
    </script>
</body>>