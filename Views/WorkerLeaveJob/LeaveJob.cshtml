@model MaidAndServantt.Controllers.LeaveJobViewModel
@{
    Layout = null;
    // Check karte hain ke kya pehle se resignation ka data database mein maujood hai
    bool hasResigned = !string.IsNullOrEmpty(ViewBag.ReasonForLeaving);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resignation Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
            body {
                background-color: #f4f6f9;
                font-family: 'Segoe UI', system-ui, sans-serif;
            }

            .main-container {
                max-width: 800px;
                margin: 3rem auto;
                background: #ffffff;
                border-radius: 20px;
                padding: 40px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }

            .profile-header {
                display: flex;
                align-items: center;
                gap: 20px;
                border-bottom: 2px solid #f1f3f5;
                padding-bottom: 20px;
                margin-bottom: 30px;
            }

            .worker-img {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                object-fit: cover;
                border: 3px solid #1e74ed;
            }

            .info-box {
                background: #f8f9fa;
                border-radius: 12px;
                padding: 15px 20px;
                margin-bottom: 15px;
            }

            .btn-custom {
                border-radius: 10px;
                font-weight: 600;
                padding: 10px 25px;
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="main-container">

            <!-- Header section with Worker profile info -->
            <div class="profile-header">
                <img src="@Model.WorkerImage" class="worker-img" alt="Worker Picture" />
                <div>
                    <h3 class="fw-bold m-0 text-dark">@Model.WorkerName</h3>
                    <span class="badge bg-primary mt-1">@Model.JobRole</span>
                </div>
            </div>

            @if (hasResigned)
            {
                <!-- ================= AB AGAR RESIGNED HAI TO YEH DIKHEGA ================= -->
                <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                    <i class="fa-solid fa-circle-exclamation fs-4 me-3"></i>
                    <div>
                        <strong>Resignation Submitted!</strong> This worker has submitted their resignation.
                    </div>
                </div>

                <h4 class="fw-bold text-dark mb-4">Resignation Details</h4>

                <div class="info-box">
                    <span class="text-muted d-block small">Reason for Leaving</span>
                    <p class="fw-bold fs-5 text-dark m-0">@ViewBag.ReasonForLeaving</p>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="info-box">
                            <span class="text-muted d-block small">Last Working Day</span>
                            <span class="fw-bold text-dark">@ViewBag.LastWorkingDay</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-box">
                            <span class="text-muted d-block small">Remaining Days</span>
                            <span class="fw-bold text-danger">@ViewBag.RemainingDays Days</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <!-- Client back dashboard par chala jaye -->
                    <a href="@Url.Action("ClientProfile", "Dashboard")" class="btn btn-secondary btn-custom">
                        <i class="fa-solid fa-arrow-left me-2"></i> Back to Dashboard
                    </a>
                </div>
            }
            else
            {
                <!-- ================= AGAR RESIGN NAHI KIYA TO FORM SUBMIT DIKHEGA ================= -->
                <h4 class="fw-bold text-dark mb-4">Submit Resignation Form</h4>

                <form asp-action="SubmitResignation" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="WorkerId" />
                    <input type="hidden" asp-for="LastWorkingDay" value="@ViewBag.LastWorkingDay" />

                    <div class="info-box mb-4">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <span class="text-muted d-block small">Suggested Last Working Day (30 Days Notice)</span>
                                <span class="fw-bold text-dark fs-5">@ViewBag.LastWorkingDay</span>
                            </div>
                            <div class="col-md-6 text-md-end mt-2 mt-md-0">
                                <span class="badge bg-secondary">Total Notice Period: @ViewBag.TotalNoticeDays Days</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Reason for Resignation</label>
                        <textarea asp-for="Reason" class="form-control" rows="4" placeholder="Please type the detailed reason here..." required></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a href="@Url.Action("WorkerDashboard", "WorkerDashboard")" class="btn btn-light btn-custom">Cancel</a>
                        <button type="submit" class="btn btn-danger btn-custom">
                            <i class="fa-solid fa-paper-plane me-2"></i> Submit Resignation
                        </button>
                    </div>
                </form>
            }

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>