@{
    Layout = null; // Default layouts bypass kar diye taake koi header/footer na aaye
    var searchTerm = ViewBag.SearchTerm as string;
    var currentFilter = ViewBag.CurrentFilter as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Interview List Web View</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
        }
        
        /* Master centering wrapper to enforce mobile web view look on all screens */
        .webview-screen-wrapper {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            width: 100%;
        }

        /* Mobile Device Frame Mockup Box */
        .mobile-webview-container {
            width: 100%;
            max-width: 450px;
            background-color: #ffffff;
            min-height: 100vh;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
            padding: 20px 16px 40px 16px;
            box-sizing: border-box;
        }

        /* Search Bar custom container */
        .custom-search-pill {
            border-radius: 30px !important;
            border: 1.2px solid #e2e8f0;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
            padding: 8px 16px;
            background-color: #fff;
        }

        /* Top Action Filter Tabs */
        .custom-pill {
            border-radius: 20px !important;
            padding: 6px 24px !important;
            font-weight: 600;
            margin-right: 6px;
            border: 1.2px solid #e2e8f0;
            color: #4a5568;
            background-color: #fff;
            text-decoration: none;
            display: inline-block;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }
            <!-- HTML mein kisi bhi jagah line 66 ke paas yeh line add karein -->
            @Html.AntiForgeryToken()
            <script >
                function approveInterview(id) {
                    if(confirm("Are you sure you want to approve this interview and hire the worker?")) {
                        $.ajax({
                            // URL ke andar hi interviewId append kar di hai
                            url: '/Dashboard/FinalApprove?interviewId=' + id,
                            type: 'POST',
                            success: function(response) {
                                if (response.success) {
                                    alert('Request Approved and Worker Hired successfully!');
                                    location.reload();
                                } else {
                                    alert('Error: ' + response.message);
                                }
                            },
                            error: function(xhr) {
                                alert('Request fail ho gayi. Status Code: ' + xhr.status);
                            }
                        });
                    }
                }
                /* function approveInterview(id) {
                    if(confirm("Are you sure you want to approve this interview and hire the worker?")) {
                        // CSRF Token ko pull karein var token = $('input[name="__RequestVerificationToken"]').val();

                        $.ajax({
                                url: '/Dashboard/FinalApprove',
                                type: 'POST',
                                data: {
                                    interviewId: id,
                                    __RequestVerificationToken: token // Token ko request body mein attach kiya
                                },
                                success: function(response) {
                                    if (response.success) {
                                        alert('Request Approved and Worker Hired successfully!');
                                        location.reload();
                                    } else {
                                        // FIX: Ab generic text ke bajaye server ka exact error msg show hoga (e.g. DB validation error)
                                        alert('Error: ' + response.message);
                                    }
                                },
                                error: function() {
                                    alert('Server se rabta nahi ho saka. Route check karein.');
                                }
                            });
                    } */
                }

    </script >

        .custom-pill.active {
            background-color: #1A73E8 !important;
            color: white !important;
            border-color: #1A73E8 !important;
            box-shadow: 0 4px 8px rgba(26,115,232,0.3);
        }

        /* Item Container Card Blocks */
        .interview-card {
            background: #ffffff;
            border: 1.5px solid #cbd5e1;
            border-radius: 16px;
            padding: 14px;
            margin-bottom: 14px;
            position: relative;
        }

        .card-border-pending { border-color: #cbd5e1 !important; }
        .card-border-approved { border-color: #2ecc71 !important; }
        .card-border-rejected { border-color: #e74c3c !important; }

        .worker-avatar {
            width: 66px;
            height: 66px;
            object-fit: cover;
            border-radius: 50%;
            border: 1.5px solid #f1f5f9;
        }

        .badge-status-top {
            font-size: 0.75rem;
            font-weight: 700;
            position: absolute;
            top: 12px;
            right: 14px;
        }

        .pill-yellow { background-color: #f1c40f; color: #fff; border-radius: 12px; padding: 2px 14px; font-weight: bold;}
        .pill-green { background-color: #2ecc71; color: #fff; border-radius: 12px; padding: 2px 14px; font-weight: bold;}
        .pill-gray { background-color: #94a3b8; color: #fff; border-radius: 12px; padding: 2px 14px; font-weight: bold;}

        .btn-action-mockup {
            border-radius: 18px !important;
            font-weight: 600;
            padding: 5px 16px;
            font-size: 0.8rem;
            width: 88px;
        }

        .btn-delete-mockup {
            color: #e74c3c;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.85rem;
            background: none;
            border: none;
            margin-top: 8px;
        }
        .btn-delete-mockup:hover { text-decoration: underline; }
    </style>
</head>
<body>

<div class="webview-screen-wrapper">
    <div class="mobile-webview-container">
        
        <!-- Header Section with working back click handler -->
        <div class="d-flex justify-content-between align-items-center mb-4 px-1">
            <div class="d-flex align-items-center gap-2">
                <button onclick="history.back()" class="btn btn-light rounded-circle border p-0 d-flex align-items-center justify-content-center" style="width:36px; height:36px; background: #fff;">
                    <i class="bi bi-arrow-left text-dark fs-5"></i>
                </button>
                <h3 class="mb-0 fw-bold text-dark" style="font-size: 1.75rem; letter-spacing: -0.5px;">Interview List</h3>
            </div>
            <div>
                <!-- Brand logo without beneath text strings -->
                <img src="/images/logo.png" alt="Logo" style="width: 44px; height: auto; display: block;" />
            </div>
        </div>

        <!-- Search Form input -->
        <form method="get" action="@Url.Action("InterviewList", "Dashboard")" class="mb-3">
            <input type="hidden" name="filterStatus" value="@currentFilter" />
            <div class="input-group custom-search-pill align-items-center">
                <span class="text-muted"><i class="bi bi-search fs-6"></i></span>
                <input type="text" name="searchTerm" value="@searchTerm" class="form-control border-0 shadow-none p-0 bg-transparent ps-3" placeholder="Search by name or skills" />
            </div>
        </form>

        <!-- Status Context Filtering Tabs -->
        <div class="mb-4 text-start px-1">
            <a class="custom-pill @(currentFilter == "All" || string.IsNullOrEmpty(currentFilter) ? "active" : "")" href="@Url.Action("InterviewList", "Dashboard", new { filterStatus = "All", searchTerm = searchTerm })">All</a>
            <a class="custom-pill @(currentFilter == "Pending" ? "active" : "")" href="@Url.Action("InterviewList", "Dashboard", new { filterStatus = "Pending", searchTerm = searchTerm })">Pending</a>
            <a class="custom-pill @(currentFilter == "Approved" ? "active" : "")" href="@Url.Action("InterviewList", "Dashboard", new { filterStatus = "Approved", searchTerm = searchTerm })">Approved</a>
        </div>

        <!-- Data Record Mapping Loop Container -->
        <div>
            @if (ViewBag.Interviews != null && ((IEnumerable<dynamic>)ViewBag.Interviews).Any())
            {
                foreach (var interview in ViewBag.Interviews)
                {
                    string cardBorderClass = "card-border-pending";
                    string topStatusLabel = "• Inprocess";
                    string statusTextColor = "text-warning";
                    string subStatusExplanation = "Worker response pending";

                    if (interview.WorkerDecision == "Approved")
                    {
                        topStatusLabel = "Interview Accepted";
                        if (interview.Status == "Pending")
                        {
                            cardBorderClass = "card-border-pending";
                            subStatusExplanation = "Awaiting Approving";
                            statusTextColor = "text-warning";
                        }
                        else
                        {
                            cardBorderClass = "card-border-approved";
                            subStatusExplanation = "Verified";
                            statusTextColor = "text-success";
                        }
                    }
                    else if (interview.WorkerDecision == "Rejected")
                    {
                        cardBorderClass = "card-border-rejected";
                        topStatusLabel = "• Interview Rejected";
                        subStatusExplanation = "Not Available right now";
                        statusTextColor = "text-danger";
                    }

                    <div class="interview-card @cardBorderClass d-flex align-items-center justify-content-between">
                        
                        <div class="badge-status-top @(interview.WorkerDecision == "Rejected" ? "text-danger" : (interview.Status == "Approved" ? "text-success" : "text-dark"))">
                            @topStatusLabel
                        </div>

                        <div class="d-flex align-items-center gap-3 text-start">
                            <div>
                                @if (!string.IsNullOrEmpty(interview.WorkerImage))
                                {
                                    <img src="@interview.WorkerImage" alt="Worker Profile" class="worker-avatar" />
                                }
                                else
                                {
                                    <div class="worker-avatar bg-light text-secondary d-flex align-items-center justify-content-center fw-bold">N/A</div>
                                }
                            </div>
                            <div>
                                <h5 class="mb-1 fw-bold text-dark" style="font-size: 1.12rem;">@interview.WorkerName</h5>
                                
                                <div class="mb-1">
                                    @if (interview.WorkerDecision == "Approved")
                                    {
                                        <span class="pill-green small">Accepted</span>
                                    }
                                    else if (interview.WorkerDecision == "Rejected")
                                    {
                                        <span class="pill-gray small">Cancel</span>
                                    }
                                    else
                                    {
                                        <span class="pill-yellow small">Pending</span>
                                    }
                                </div>
                                
                                <span class="text-muted small d-block" style="font-size:0.82rem;">@(interview.SkillName ?? "Maid")</span>
                                <div class="small mt-1 fw-bold @statusTextColor" style="font-size: 0.78rem;">@subStatusExplanation</div>
                            </div>
                        </div>

                        <div class="d-flex flex-column align-items-center justify-content-center pt-3">
                            @if (interview.WorkerDecision == "Approved" && interview.Status == "Pending")
                            {
                                <button onclick="approveInterview(@interview.InterviewId)" class="btn btn-success btn-action-mockup text-white shadow-sm" style="background-color: #2ecc71; border-color: #2ecc71;">
                                    Approve
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-light btn-action-mockup text-muted border-0" disabled style="background-color: #e2e6ea;">
                                    Approve
                                </button>
                            }
                            <button onclick="deleteRequest(@interview.InterviewId)" class="btn-delete-mockup">Delete</button>
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="text-center p-5 bg-white rounded-3 border mt-2">
                    <p class="text-muted mb-0">No interview requests found.</p>
                </div>
            }
        </div>
    </div>
</div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function approveInterview(id) {
        if(confirm("Are you sure you want to approve this interview and hire the worker?")) {
        $.ajax({
        url: '/Dashboard/FinalApprove?interviewId=' + id, // URL parameters explicit binding
        type: 'POST',
        success: function(response) {
        if (response.success) {
        alert('Request Approved and Worker Hired successfully!');
        location.reload();
        } else {
        alert('Error: ' + response.message);
        }
        },
        error: function(xhr) {
        alert('Request failed. Status Code: ' + xhr.status);
        }
        });
        }
        }

        function deleteRequest(id) {
        if(confirm("Are you sure you want to delete this record?")) {
        $.post('/Dashboard/DeleteRequest', { interviewId: id }, function(response) {
        if (response.success) {
        alert('Record deleted successfully.');
        location.reload();
        } else {
        alert('Delete karne mein koi masla aya.');
        }
        });
        }
        }
    </script>
</body>
</html>